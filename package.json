{
  "name": "sticktogif",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:web",
    "build:web": "tsc -b && vite build --mode web",
    "build:mobile": "tsc -b && vite build --mode mobile",
    "check:mobile-secrets": "./scripts/check-mobile-secrets.sh",
    "version:sync": "node ./scripts/sync-mobile-version.mjs",
    "version:bump:patch": "npm version patch --no-git-tag-version",
    "version:bump:minor": "npm version minor --no-git-tag-version",
    "version:bump:major": "npm version major --no-git-tag-version",
    "version": "npm run version:sync && git add package.json package-lock.json android/app/build.gradle ios/App/StickToGif.xcodeproj/project.pbxproj",
    "cap:sync": "npm run check:mobile-secrets && npm run version:sync && npm run build:mobile && node ./scripts/cap-sync.mjs",
    "cap:ios": "npm run cap:sync && open ios/App/StickToGif.xcodeproj",
    "cap:android": "npx cap open android",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/share": "^8.0.1",
    "@techstark/opencv-js": "^4.12.0-release.1",
    "gifenc": "^1.0.3",
    "gifuct-js": "^2.1.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
